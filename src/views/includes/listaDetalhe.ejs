<%- include('header') %>
<%- include('navbarMyAgenda') %>

<div class="container">
  <div class="row">
    <div class="col-lg-2"></div>

    <div class="col-lg-8 my-4">

      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="m-0"><%= lista.nome %></h2>

        <button class="btn btn-dark" data-bs-toggle="modal" data-bs-target="#modalContato">
          + Novo Contato
        </button>
      </div>

      <!-- CONTATOS -->
      <% if (!contatos || contatos.length === 0) { %>
        <div class="text-center mt-4">
          <p class="text-muted">Nenhum contato nesta lista</p>
        </div>
      <% } else { %>

      <ul class="list-group">
        <% contatos.forEach(contato => { %>
          <li class="list-group-item d-flex justify-content-between">
            <div>
              <strong><%= contato.nome %></strong><br>
              <small><%= contato.telefone %></small>
            </div>

            <form action="/contatos/delete/<%= contato._id %>" method="POST">
              <button class="btn btn-sm btn-outline-danger">Excluir</button>
            </form>
          </li>
        <% }) %>
      </ul>

      <% } %>

    </div>

    <div class="col-lg-2"></div>
  </div>
</div>

<!-- MODAL CONTATO -->
<div class="modal fade" id="modalContato" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Novo Contato</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <form action="/contatos/create/<%= lista._id %>" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="modal-body">
          <input type="text" name="nome" class="form-control mb-2" placeholder="Nome" required>
          <input type="text" name="telefone" class="form-control" placeholder="Telefone">
        </div>

        <div class="modal-footer">
          <button class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button class="btn btn-dark">Salvar</button>
        </div>
      </form>

    </div>
  </div>
</div>

<%- include('footer') %>