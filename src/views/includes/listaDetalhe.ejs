<%- include('header') %>
<%- include('navbarMyAgenda') %>

<div class="container">
  <div class="row">
    <div class="col-lg-2"></div>

    <div class="col-lg-8 my-4">

      <!-- HEADER -->
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="m-0"><%= lista.nome %></h2>

        <button class="btn btn-dark" data-bs-toggle="modal" data-bs-target="#modalContato">
          + Novo Contato
        </button>
      </div>

      <!-- DESCRIÇÃO -->
      <div class="card mb-4 shadow-sm">
        <div class="card-body" style="max-height: 150px; overflow-y: auto;">

          <div class="d-flex justify-content-between align-items-start mb-2">
            <h6 class="text-muted m-0">Descrição</h6>

            <!-- BOTÃO EDITAR -->
            <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#modalDescricao">
              Editar
            </button>
          </div>

            <!-- TEXTO DE DESCRIÇÃO -->
            <% if (lista.descricao && lista.descricao.trim() !== '') { %>
              <p class="mb-0"><%= lista.descricao %></p>
            <% } else { %>
              <p class="text-muted fst-italic mb-0">
                Nenhuma descrição adicionada.
              </p>
            <% } %>

        </div>
      </div>

      <!-- FILTRO DE ORDENAÇÃO -->
      <div class="d-flex justify-content-between align-items-center mb-3">

        <h5 class="m-0">Contatos</h5>

        <form method="GET" action="/listas/<%= lista._id %>" class="d-flex">
          <select id="ordenarSelect" name="ordenar" class="form-select form-select-sm me-2"">
            <option value="">Ordenar por</option>
            <option value="nome" <%= (query.ordenar === 'nome') ? 'selected' : '' %>> A-Z </option>
            <option value="recentes" <%= (query.ordenar === 'recentes') ? 'selected' : '' %>> Mais recentes </option>
            <option value="antigos" <%= (query.ordenar === 'antigos') ? 'selected' : '' %>> Mais antigos </option>
          </select>
        </form>

      </div>

      <!-- CONTATOS -->
      <div class="card shadow-sm">
        <div class="card-body p-2">

          <% if (!contatos || contatos.length === 0) { %>

            <div class="text-center p-4">
              <p class="text-muted m-0">Nenhum contato nesta lista</p>
            </div>

          <% } else { %>

            <ul class="list-group list-group-flush">
              <% contatos.forEach(contato => { %>

                <li class="list-group-item d-flex justify-content-between align-items-center">

                  <div>

                    <strong class="d-block mb-1">
                      <% if (contato.sobrenome) { %>
                        <%= contato.nome %> <%= contato.sobrenome %>
                      <% } else { %>
                        <%= contato.nome %>
                      <% } %>
                    </strong>

                    <div class="text-muted small">

                      <% if (contato.telefone) { %>
                        <div class="mb-1">
                          📞 <%= contato.telefone %>
                        </div>
                      <% } %>

                      <% if (contato.email) { %>
                        <div>
                          ✉ <%= contato.email %>
                        </div>
                      <% } %>

                    </div>

                  </div>

                  <form action="/contatos/delete/<%= contato._id %>" method="POST" class="m-0">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button class="btn btn-sm btn-outline-danger">
                      Excluir
                    </button>
                  </form>

                </li>

              <% }) %>
            </ul>

          <% } %>

        </div>
      </div>

    </div>

    <div class="col-lg-2"></div>
  </div>
</div>

<!-- MODAL CONTATO -->
<div class="modal fade" id="modalContato" tabindex="-1" data-tem-erros="<%= Object.keys(errorsObj).length > 0 %>">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Novo Contato</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <form action="/contatos/create/<%= lista._id %>" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <div class="modal-body">
          <input type="text" name="nome" class="form-control mb-2 <%- errorsObj.nome ? 'is-invalid' : '' %>" placeholder="Nome">
          <% if (errorsObj.nome) { %>
            <div class="invalid-feedback mb-2">
              <%= errorsObj.nome %>
            </div>
          <% } %>

          <input type="text" name="sobrenome" class="form-control mb-2" placeholder="Sobrenome">

          <input type="text" name="telefone" class="form-control <%- errorsObj.contato ? 'is-invalid' : '' %>" placeholder="Telefone">
          <% if (errorsObj.contato) { %>
            <div class="invalid-feedback mb-2">
              <%= errorsObj.contato %>
            </div>
          <% } %>

          <input type="email" name="email" class="form-control mb-2 <%- errorsObj.contato ? 'is-invalid' : '' %>" placeholder="Email">
          <% if (errorsObj.contato) { %>
            <div class="invalid-feedback mb-2">
              <%= errorsObj.contato %>
            </div>
          <% } %>

        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-dark">Salvar</button>
        </div>
      </form>

    </div>
  </div>
</div>

<!-- MODAL DESCRIÇÃO -->
 <div class="modal fade" id="modalDescricao" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">

      <div class="modal-header">
        <h5 class="modal-title">Editar descrição</h5>
        <button class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <form action="/listas/descricao/<%= lista._id %>" method="POST">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">

        <div class="modal-body">
          <textarea 
            name="descricao" 
            class="form-control" 
            rows="4"
            placeholder="Digite uma descrição..."
          ><%= lista.descricao %></textarea>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
          <button type="submit" class="btn btn-dark">Salvar</button>
        </div>

      </form>

    </div>
  </div>
</div>

<script src="/assets/js/modal.js"></script>

<%- include('footer') %>